# --- LLM provider ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Used by the Risk Officer agent only.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Used by the 3 narrow sub-agents (sentiment/fundamental/technical) — cheaper
# model since they only interpret an already-computed number, not decide a trade.
ANTHROPIC_SUBAGENT_MODEL=claude-haiku-4-5-20251001

# --- OpenBB data providers (set whichever providers you've configured) ---
OPENBB_PAT=

# --- Alpaca broker ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading is the hardcoded default (see config/settings.py).
# To go live you must set BOTH of the following explicitly — there is no single switch:
#   TRADING_ENV=live
#   TRADING_LIVE_CONFIRM=I_UNDERSTAND_THIS_IS_LIVE_CAPITAL
# Leaving either unset (or any other value) keeps the system on the paper sandbox.
TRADING_ENV=paper
TRADING_LIVE_CONFIRM=

# --- Risk guardrails (hard limits enforced in code, not just config) ---
MAX_POSITION_SIZE_PCT=0.05
MAX_DAILY_DRAWDOWN_PCT=0.02
# Conservative-by-design: stop trading and close positions for the day once
# the day's gain reaches this many dollars, rather than risk giving it back.
DAILY_PROFIT_TARGET_USD=50.0

# --- State persistence ---
STATE_DB_PATH=./state/trading_engine.sqlite3
